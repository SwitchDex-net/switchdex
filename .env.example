# ── SwitchDex configuration ─────────────────────────────────────────
# Copy to `.env` and edit. On the appliance image, firstboot generates
# this automatically with random secrets.

# Database
POSTGRES_USER=switchdex
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=switchdex

# App secret (sessions / token signing) — make this long and random
SECRET_KEY=change-me-to-a-long-random-string

# Device access backend:
#   real = talk to live devices via NAPALM / Netmiko / asyncssh (default)
#   sim  = simulated devices, for evaluation without hardware
DEVICE_BACKEND=real

# Populate 4 fake demo devices on first run (for evaluation/screenshots).
# Leave false for a real deployment — you'll add your own devices.
SEED_DEMO_DEVICES=false

# Default SSH credentials for discovery/backup (per-device creds override these).
# Stored server-side only — never sent to the browser.
DEFAULT_SSH_USERNAME=netops
DEFAULT_SSH_PASSWORD=
DEFAULT_SNMP_COMMUNITY=public

# Scheduled backup time (24h, server local time)
BACKUP_HOUR=2
BACKUP_MINUTE=0

# How many devices the scheduler backs up in parallel during the nightly run.
# Higher = faster runs but bigger CPU/RAM/network spike. Tune up for large fleets:
#   ~150 devices: 10 (default)   500 devices: 25   2000+ devices: 50
BACKUP_CONCURRENCY=10

# Telemetry (time-series). Sample interval in seconds; how long to keep raw
# per-sample rows; how long to keep downsampled hourly data.
METRICS_INTERVAL=300
METRICS_RAW_RETENTION_DAYS=7
METRICS_HOURLY_RETENTION_DAYS=90

# Hostname the appliance answers on (Caddy uses this for the TLS cert).
# Use the appliance IP or a DNS name. "localhost" -> internal self-signed.
PUBLIC_HOSTNAME=localhost

# How Caddy handles TLS:
#   internal  (default) — self-signed cert for direct access by IP/localhost.
#   auto                — real Let's Encrypt cert; needs PUBLIC_HOSTNAME to be a
#                         public DNS name Caddy can validate.
#   http                — plain HTTP (no TLS), for running BEHIND a reverse proxy
#                         (NGINX Proxy Manager, Traefik, etc.) that terminates
#                         TLS itself. Point your proxy at http://<ip>:80 — this
#                         avoids the self-signed-cert 502 / upstream-verify issue.
# After changing this, rebuild caddy:
#   docker compose build --no-cache caddy && docker compose up -d --force-recreate caddy
# See docs/DEPLOY.md "Running behind a reverse proxy" for the full proxy setup.
TLS_MODE=internal
