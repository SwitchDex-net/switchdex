# Caddy terminates TLS, serves the built frontend, and proxies the API +
# WebSocket SSH stream to the backend.
#
# TLS strategy:
#   - A real DNS name in PUBLIC_HOSTNAME -> Caddy gets a Let's Encrypt cert.
#   - A bare IP or "localhost"           -> Caddy serves a self-signed cert
#     from its internal CA.
#
# default_sni is required for the bare-IP case: browsers and curl do NOT send
# SNI when connecting to an IP address, so without this Caddy can't decide
# which certificate to present and aborts the handshake with a TLS "internal
# error". Pinning default_sni to the configured hostname makes the IP work.

{
	default_sni {$PUBLIC_HOSTNAME:localhost}
}

{$PUBLIC_HOSTNAME:localhost} {
	# self-signed cert from Caddy's internal CA (used for IP / localhost)
	tls internal

	# API + WebSocket -> FastAPI backend
	handle /api/* {
		reverse_proxy backend:8000
	}
	handle /ws/* {
		reverse_proxy backend:8000
	}

	# Everything else -> static frontend (built React app baked into the image)
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
