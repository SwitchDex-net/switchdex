# Caddy terminates TLS (or serves plain HTTP when behind a reverse proxy),
# serves the built frontend, and proxies the API + WebSocket SSH stream to the
# backend.
#
# TLS_MODE (set in .env) selects the strategy:
#   internal  (default) — self-signed cert from Caddy's internal CA, for direct
#                         access by IP or localhost. Accept the browser warning.
#   auto                — real Let's Encrypt cert. Requires PUBLIC_HOSTNAME to be
#                         a public DNS name that resolves to this host and that
#                         Caddy can reach LE from. Best for direct internet access.
#   http                — plain HTTP, no TLS. For running BEHIND a reverse proxy
#                         (NGINX Proxy Manager, Traefik, etc.) that terminates TLS
#                         itself. Eliminates the self-signed-cert 502 / upstream
#                         verification problems — the proxy connects to plain HTTP.
#
# default_sni is required for the bare-IP internal case: browsers and curl do NOT
# send SNI when connecting to an IP, so without it Caddy can't pick a cert.

# The entrypoint always exports SITE_ADDRESS, TLS_DIRECTIVE, and
# CADDY_GLOBAL_EXTRA (one set per TLS_MODE), so they are referenced here without
# nested defaults — Caddy's {$VAR:default} does NOT support a nested {$VAR:...}
# as the default, which is a parse error.
{
	{$CADDY_GLOBAL_EXTRA}
}

{$SITE_ADDRESS} {
	{$TLS_DIRECTIVE}

	# API + WebSocket -> FastAPI backend
	handle /api/* {
		reverse_proxy backend:8000
	}
	handle /ws/* {
		reverse_proxy backend:8000
	}

	# Everything else -> static frontend (built React app baked into the image)
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
