#cloud-config
# Ubuntu 24.04 unattended autoinstall used by Packer to build the appliance.
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  ssh:
    install-server: true
    allow-pw: true
  identity:
    hostname: switchdex
    username: switchdex
    # password "switchdex" (locked down by firstboot.sh on first boot)
    password: "$6$rounds=4096$saltsalt$3oP1Bb8h9sUu9Dz0gJ4QZ0kBq3p1qP2c3Q9k0wq8gJ0r6QmZ8sN9c9aXk4qV1u/2hQ7e1n2bV0c3d4e5f6g7"
  storage:
    layout:
      name: lvm
  packages:
    - ca-certificates
    - curl
    - git
  late-commands:
    # passwordless sudo so Packer provisioning can run
    - echo 'switchdex ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/switchdex
